# Base de datos SQLite (desarrollo local)
DATABASE_URL="file:./dev.db"

# Para Vercel/Producción con Turso (libSQL - SQLite compatible)
# 1. Crea una cuenta en https://turso.tech
# 2. Crea una base de datos
# 3. Obtén la URL y token de autenticación
# DATABASE_URL="libsql://tu-db-usuario.turso.io?authToken=tu-auth-token"

# Alternativas para Vercel/Producción:
# Neon (PostgreSQL): DATABASE_URL="postgresql://user:pass@host/db"
# Vercel Postgres: DATABASE_URL="postgres://user:pass@host/db"
# PlanetScale (MySQL): DATABASE_URL="mysql://user:pass@host/db"

# API de IA (para análisis con IA, opcional)
# OPENAI_API_KEY="tu-api-key"
