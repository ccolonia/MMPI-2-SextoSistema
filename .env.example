# Base de datos SQLite (desarrollo local)
DATABASE_URL="file:./dev.db"

# Para Vercel/Producción, usa una base de datos persistente como:
# Turso: DATABASE_URL="libsql://tu-db.turso.io"
# Neon: DATABASE_URL="postgresql://user:pass@host/db"
# Vercel Postgres: DATABASE_URL="postgres://user:pass@host/db"

# API de IA (para análisis con IA, opcional)
# OPENAI_API_KEY="tu-api-key"
