# Base de datos PostgreSQL para Vercel/Producción
# Recomendado: Neon (https://neon.tech) - Gratis y serverless

# DATABASE_URL - URL de conexión para consultas (con pooling)
DATABASE_URL="postgresql://usuario:contraseña@ep-xxx.us-east-2.aws.neon.tech/mmpi2?sslmode=require"

# DIRECT_DATABASE_URL - URL directa para migraciones (sin pooling)
DIRECT_DATABASE_URL="postgresql://usuario:contraseña@ep-xxx.us-east-2.aws.neon.tech/mmpi2?sslmode=require"

# Para desarrollo local con SQLite:
# DATABASE_URL="file:./dev.db"
# DIRECT_DATABASE_URL="file:./dev.db"

# API de IA (para análisis con IA, opcional)
# OPENAI_API_KEY="tu-api-key"
