// Informe MMPI-2 guardado
model InformeMMPI2 {
  id                String   @id @default(cuid())

  // Datos del evaluado
  nombreEvaluado    String?
  edad              Int?
  sexo              String?   // "masculino" | "femenino"
  contextoEvaluacion String?
  motivoConsulta    String?
  fechaEvaluacion   String?
  evaluador         String?
  institucion       String?

  // Escalas de validez
  omisiones         Int      @default(0)
  vrint             Int      @default(50)
  trint             Int      @default(50)
  fBruto            Int      @default(0)
  fT                Int      @default(50)
  fbT               Int      @default(50)
  fpBruto           Int      @default(0)
  f_K               Int      @default(0)
  lBruto            Int      @default(0)
  kBruto            Int      @default(0)

  // Escalas clínicas (Puntajes T)
  hsT               Int      @default(50)
  dT                Int      @default(50)
  hyT               Int      @default(50)
  pdT               Int      @default(50)
  mfT               Int      @default(50)
  paT               Int      @default(50)
  ptT               Int      @default(50)
  scT               Int      @default(50)
  maT               Int      @default(50)
  siT               Int      @default(50)

  // Resultado del análisis (JSON completo)
  analysisResult    String   // JSON stringificado

  // PDF generado (base64 o path)
  pdfPath           String?

  // Metadatos
  notas             String?  // Notas adicionales del evaluador

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
